generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DIRECTEUR
  ASSISTANTE
  AGENT
}

model User {
  id         String   @id @default(cuid())

  firstname  String
  lastname   String

  email      String   @unique
  password   String

  role       Role @default(AGENT)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}